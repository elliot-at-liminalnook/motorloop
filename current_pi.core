CAPI=2:
# SPDX-License-Identifier: MIT
name: motorloop:ip:current_pi:0.1.0
description: "Single-axis current PI with anti-windup clamp (PROVEN)"
filesets:
  rtl:
    files:
      - rtl/current_pi.v
    file_type: verilogSource
targets:
  default: &default
    filesets: [rtl]
    toplevel: current_pi
  lint:
    <<: *default
    default_tool: verilator
    tools:
      verilator:
        mode: lint-only

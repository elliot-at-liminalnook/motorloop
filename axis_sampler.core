name: motorloop:ip:axis_sampler:0.1.0
description: "AXI4-Stream telemetry sampler (protocol PROVEN)"
filesets:
  rtl:
    files:
      - rtl/bus/axis_sampler.v
    file_type: verilogSource
targets:

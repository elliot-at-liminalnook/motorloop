CAPI=2:
# SPDX-License-Identifier: MIT
name: motorloop:ip:axil_regfile:0.1.0
description: "AXI4-Lite register slave for the controller (protocol PROVEN)"
filesets:
  rtl:
    files:
      - rtl/bus/axil_regfile.v
    file_type: verilogSource
targets:
  default: &default
    filesets: [rtl]
    toplevel: axil_regfile
  lint:
    <<: *default
    default_tool: verilator
    tools:
      verilator:
        mode: lint-only

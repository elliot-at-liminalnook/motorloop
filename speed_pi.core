CAPI=2:
# SPDX-License-Identifier: MIT
name: motorloop:ip:speed_pi:0.1.0
description: "Six-step speed PI with down-slew limit"
filesets:
  rtl:
    files:
      - rtl/speed_pi.v
    file_type: verilogSource
targets:
  default: &default
    filesets: [rtl]
    toplevel: speed_pi
  lint:
    <<: *default
    default_tool: verilator
    tools:
      verilator:
        mode: lint-only

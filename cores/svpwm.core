CAPI=2:
# SPDX-License-Identifier: MIT
name: motorloop:ip:svpwm:0.1.0
description: "Space-vector PWM by min/max injection, combinational"
filesets:
  rtl:
    files:
      - ../rtl/svpwm.v
    file_type: verilogSource
targets:
  default: &default
    filesets: [rtl]
    toplevel: svpwm
  lint:
    <<: *default
    default_tool: verilator
    tools:
      verilator:
        mode: lint-only

CAPI=2:
# SPDX-License-Identifier: MIT
name: motorloop:ip:speed_meter:0.1.0
description: "Sector-edge speed measurement"
filesets:
  rtl:
    files:
      - ../rtl/speed_meter.v
      - ../rtl/divider32.v
    file_type: verilogSource
targets:
  default: &default
    filesets: [rtl]
    toplevel: speed_meter
  lint:
    <<: *default
    default_tool: verilator
    tools:
      verilator:
        mode: lint-only

CAPI=2:
# SPDX-License-Identifier: MIT
name: motorloop:ip:clarke:0.1.0
description: "Clarke transform (3-phase -> alpha/beta), combinational"
filesets:
  rtl:
    files:
      - rtl/clarke.v
    file_type: verilogSource
targets:
  default: &default
    filesets: [rtl]
    toplevel: clarke
  lint:
    <<: *default
    default_tool: verilator
    tools:
      verilator:
        mode: lint-only

CAPI=2:
# SPDX-License-Identifier: MIT
name: motorloop:ip:spi_drv_master:0.1.0
description: "SPI master, mode-1 16-bit (gate driver)"
filesets:
  rtl:
    files:
      - rtl/spi_drv_master.v
    file_type: verilogSource
targets:
  default: &default
    filesets: [rtl]
    toplevel: spi_drv_master
  lint:
    <<: *default
    default_tool: verilator
    tools:
      verilator:
        mode: lint-only

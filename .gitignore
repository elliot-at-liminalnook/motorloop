# Build outputs
build/
sim/build/
rtl/gen/
synth/work/
fusesoc.conf
out/

# Generated docs site (robotics-ip stage 7): site-src/ is assembled by
# scripts/gen_docs.py from notes/ + rtl/contracts/; site/ is the mkdocs render.
site-src/
site/

# Vendor collateral: TI/Sipeed/Gowin/etc. datasheets, reference designs, and
# SPICE models are copyrighted and not redistributable. The README.md index
# in each docs/ subdirectory lists what to download and from where.
docs/*
!docs/datasheets/
docs/datasheets/*
!docs/datasheets/README.md
!docs/ti-app-notes/
docs/ti-app-notes/*
!docs/ti-app-notes/README.md
!docs/ti-reference-boards/
docs/ti-reference-boards/*
!docs/ti-reference-boards/README.md
!docs/ti-simulation-models/
docs/ti-simulation-models/*
!docs/ti-simulation-models/README.md

# Caches and tool litter
__pycache__/
*.pyc
.pytest_cache/
MUJOCO_LOG.TXT
*.blend1
*.vcd
*.fst

# Formal proof outputs (regenerated by formal/run_formal.py); the manifest,
# checkers, and the generated proof_report.md are tracked, the work dir is not.
formal/work/
formal/sby/*.sby

# cocotb block-test artifacts (robotics-ip)
sim/cocotb/build/
sim/cocotb/sim_build/
sim/cocotb/*.result.xml
*.vcd
